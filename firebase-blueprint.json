{
  "entities": {
    "Episode": {
      "title": "Podcast Episode",
      "description": "A single podcast episode with audio and metadata.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the episode."
        },
        "description": {
          "type": "string",
          "description": "A brief description of the episode content."
        },
        "audioUrl": {
          "type": "string",
          "format": "uri",
          "description": "The URL to the audio file (mp3/m4a)."
        },
        "duration": {
          "type": "number",
          "description": "Duration in seconds."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the episode was published."
        },
        "authorId": {
          "type": "string",
          "description": "The UID of the user who published the episode."
        }
      },
      "required": ["title", "audioUrl", "createdAt", "authorId"]
    },
    "User": {
      "title": "User Profile",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "listener"] }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "episodes": {
      "schema": "Episode",
      "description": "Collection of podcast episodes."
    },
    "users": {
      "schema": "User",
      "description": "Collection of user profiles."
    }
  }
}
